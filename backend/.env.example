# AstroLog Backend Environment Variables
# Set these in your environment or in application.properties

# AstronomyAPI Configuration
ASTRONOMY_API_KEY=your_astronomy_api_key_here

# Database Configuration (if using PostgreSQL)
DATABASE_URL=jdbc:postgresql://localhost:5432/astrolog
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=your_password

# Storage Configuration
STORAGE_TYPE=local
STORAGE_LOCAL_PATH=./uploads

# AWS S3 (if using S3 storage)
AWS_S3_BUCKET_NAME=your-bucket-name
AWS_S3_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key

# CORS Configuration
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# Server Port
SERVER_PORT=8080

# Logging Level
LOG_LEVEL=INFO

